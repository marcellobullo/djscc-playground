  parameters:
    affinity: ''
    alias: ''
    comment: '64+16 = 80

      25 symbols *80 = 2000'
    cp_len: int(fft_len/4)
    input_size: fft_len
    maxoutbuf: '0'
    minoutbuf: '0'
    rolloff: '0'
    tagname: length_tag_key
  states:
