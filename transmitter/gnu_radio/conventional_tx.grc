- name: digital_packet_headergenerator_bb_0
  id: digital_packet_headergenerator_bb
  parameters:
    affinity: ''
    alias: ''
    comment: 'Samples: 48'
    header_formatter: deepjscc.packet_header_ofdm_wide(occupied_carriers, n_syms=1,
