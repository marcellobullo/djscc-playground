  parameters:
    affinity: ''
    alias: ''
    comment: 'Sync1 (1*64) + Sync2(1*64) = 128

      Header (1*64) = 64

      Payload(22*64) = 1408

      Total = 25 symbols or 1600 samples'
    fft_len: fft_len
    len_tag_key: length_tag_key
    maxoutbuf: '0'
    minoutbuf: '0'
    occupied_carriers: occupied_carriers
    output_is_shifted: 'True'
    pilot_carriers: pilot_carriers
    pilot_symbols: pilot_symbols
    sync_words: (sync_word1, sync_word2)
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [480, 1192.0]
    rotation: 0
    state: enabled
- name: digital_ofdm_cyclic_prefixer_0
