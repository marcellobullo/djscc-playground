- name: pilot_phase_track_0
  id: epy_block
  parameters:
    _source_code: "\"\"\"Per-OFDM-symbol pilot-based phase de-rotation with a coherence\
      \ gate.\n\nSits between digital_ofdm_frame_equalizer_vcvc_1 (static payload\
      \ equalizer,\nno pilot tracking) and the payload serializer + pilot_snr_logger.\
      \ For each\ninput OFDM vector this block:\n\n  1. Extracts the 4 pilot subcarriers.\n\
      \  2. Computes  est = mean(pilot_received * conj(pilot_expected))\n     whose\
      \ phase is the residual rotation of that OFDM symbol.\n  3. ONLY applies a per-symbol\
      \ phase derotation when |est| is close to its\n     ideal unit magnitude \u2014\
      \ i.e. when the four pilots agree. If pilots are\n     noise-dominated (e.g.\
      \ pilot subcarriers fall in a frequency-selective\n     fade) the phase estimate\
      \ is unreliable, and applying it would *add*\n     random rotations rather than\
      \ remove drift. In that case the block is a\n     strict pass-through. This\
      \ guarantees the block never makes the signal\n     worse than the static-EQ\
      \ baseline.\n\nA diagnostic line is printed every `log_every` OFDM symbols reporting\
      \ the\nfraction actually corrected and the mean |est|. If mean |est| sits well\n\
      below 1, the pilots in this channel are too noisy for per-symbol tracking\n\
      and the fix needs to live elsewhere (e.g. MMSE equalization, or moving\npilots\
      \ off a fade).\n\nThis is NOT decision-feedback equalization: continuous-valued\
      \ DJSCC\nsymbols pass through with unchanged modulus.\n\"\"\"\n\nimport numpy\
      \ as np\nimport pmt\nfrom gnuradio import gr\n\n\nclass blk(gr.sync_block):\n\
      \    def __init__(self, fft_len=64,\n                 pilot_positions=[11, 25,\
      \ 39, 53],\n                 pilot_symbols=[1.0, 1.0, 1.0, -1.0],\n        \
      \         coh_thresh=0.5,\n                 log_every=4096):\n        gr.sync_block.__init__(\n\
      \            self,\n            name='pilot_phase_track',\n            in_sig=[(np.complex64,\
      \ fft_len)],\n            out_sig=[(np.complex64, fft_len)],\n        )\n  \
      \      self.pilot_positions = np.array(pilot_positions, dtype=np.int64)\n  \
      \      self.pilot_symbols = np.array(pilot_symbols, dtype=np.complex64)\n  \
      \      self.pilot_conj = np.conj(self.pilot_symbols).astype(np.complex64)\n\
      \        self.coh_thresh = float(coh_thresh)\n        self.log_every = int(log_every)\n\
      \        self._n_seen = 0\n        self._n_corrected = 0\n        self._mag_sum\
      \ = 0.0\n\n    def work(self, input_items, output_items):\n        in0 = input_items[0]\n\
      \        out0 = output_items[0]\n        n = len(in0)\n        if n == 0:\n\
      \            return 0\n        pilots = in0[:, self.pilot_positions]\n     \
      \   cross = pilots * self.pilot_conj[None, :]\n        est = cross.mean(axis=1)\n\
      \        mag = np.abs(est)\n        safe = mag > self.coh_thresh\n        correction\
      \ = np.ones(n, dtype=np.complex64)\n        if np.any(safe):\n            correction[safe]\
      \ = (est[safe].conj()\n                                / np.maximum(mag[safe],\
      \ 1e-9)\n                                ).astype(np.complex64)\n        out0[:]\
      \ = (in0 * correction[:, None]).astype(np.complex64)\n        self._n_seen +=\
      \ n\n        self._n_corrected += int(safe.sum())\n        self._mag_sum +=\
      \ float(mag.sum())\n        if self._n_seen >= self.log_every:\n           \
      \ mean_mag = self._mag_sum / max(self._n_seen, 1)\n            ratio = self._n_corrected\
      \ / max(self._n_seen, 1)\n            print('[pilot_phase_track] last %d syms:\
      \ corrected %.0f%% | '\n                  'mean |est|=%.3f (gate=%.2f)'\n  \
      \                % (self._n_seen, ratio * 100.0, mean_mag, self.coh_thresh))\n\
      \            self._n_seen = 0\n            self._n_corrected = 0\n         \
      \   self._mag_sum = 0.0\n        return n\n"
    affinity: ''
    alias: ''
    coh_thresh: '0.5'
    comment: Per-OFDM-symbol pilot phase derotation (fixes residual CFO/SCO drift)
    fft_len: fft_len
    log_every: '4096'
    maxoutbuf: '0'
    minoutbuf: '0'
    pilot_positions: '[11, 25, 39, 53]'
    pilot_symbols: '[1.0, 1.0, 1.0, -1.0]'
  states:
    _io_cache: ('pilot_phase_track', 'blk', [('fft_len', '64'), ('pilot_positions',
      '[11, 25, 39, 53]'), ('pilot_symbols', '[1.0, 1.0, 1.0, -1.0]'), ('coh_thresh',
      '0.5'), ('log_every', '4096')], [('0', 'complex', 64)], [('0', 'complex', 64)],
      '', ['coh_thresh', 'log_every', 'pilot_positions', 'pilot_symbols'])
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [936, 980.0]
    rotation: 0
    state: disabled
- name: pilot_snr_logger_0
  id: epy_block
  parameters:
    _source_code: "\"\"\"Per-frame equalized-pilot logger for offline SNR estimation.\"\
      \"\"\n\nimport threading\nimport numpy as np\nimport pmt\nfrom gnuradio import\
      \ gr\n\n\nclass blk(gr.sync_block):\n    def __init__(self, fft_len=64,\n  \
      \               pilot_positions=[11, 25, 39, 53],\n                 pilot_symbols=[1.0,\
      \ 1.0, 1.0, -1.0],\n                 out_path='/tmp/pilot_dataset.npz',\n  \
      \               flush_every=200):\n        gr.sync_block.__init__(\n       \
      \     self,\n            name='pilot_snr_logger',\n            in_sig=[(np.complex64,\
      \ fft_len)],\n            out_sig=None,\n        )\n        self.fft_len = int(fft_len)\n\
      \        self.pilot_positions = np.array(pilot_positions, dtype=np.int64)\n\
      \        self.pilot_symbols = np.array(pilot_symbols, dtype=np.complex64)\n\
      \        self.out_path = str(out_path)\n        self.flush_every = int(flush_every)\n\
      \        self.pkt_num_key = pmt.intern('packet_num')\n        self.frame_len_key\
      \ = pmt.intern('frame_len')\n\n        self._curr_pn = None\n        self._curr_fl\
      \ = 0\n        self._curr_consumed = 0\n        self._curr_pilots = []\n\n \
      \       self.pn_list = []\n        self.mean_pilots_list = []\n        self.sigma2_list\
      \ = []\n        self._lock = threading.Lock()\n        self.snr_part_port =\
      \ pmt.intern('snr_part')\n        self.message_port_register_out(self.snr_part_port)\n\
      \n    def work(self, input_items, output_items):\n        in0 = input_items[0]\n\
      \        n = len(in0)\n        nread = self.nitems_read(0)\n\n        tag_map\
      \ = {}\n        for tag in self.get_tags_in_window(0, 0, n, self.pkt_num_key):\n\
      \            tag_map.setdefault(int(tag.offset - nread), {})['pn'] = pmt.to_long(tag.value)\n\
      \        for tag in self.get_tags_in_window(0, 0, n, self.frame_len_key):\n\
      \            tag_map.setdefault(int(tag.offset - nread), {})['fl'] = pmt.to_long(tag.value)\n\
      \n        for i in range(n):\n            if i in tag_map:\n               \
      \ self._finalize_frame()\n                info = tag_map[i]\n              \
      \  self._curr_pn = info.get('pn')\n                self._curr_fl = info.get('fl',\
      \ 0)\n                self._curr_consumed = 0\n                self._curr_pilots\
      \ = []\n            if self._curr_pn is not None and self._curr_consumed < self._curr_fl:\n\
      \                self._curr_pilots.append(in0[i][self.pilot_positions])\n  \
      \              self._curr_consumed += 1\n                if self._curr_consumed\
      \ >= self._curr_fl:\n                    self._finalize_frame()\n        return\
      \ n\n\n    def _finalize_frame(self):\n        if self._curr_pn is None or not\
      \ self._curr_pilots:\n            self._curr_pn = None\n            self._curr_pilots\
      \ = []\n            self._curr_consumed = 0\n            self._curr_fl = 0\n\
      \            return\n        arr = np.array(self._curr_pilots, dtype=np.complex64)\n\
      \        mean_p = arr.mean(axis=0)\n        n_eq = arr - self.pilot_symbols[None,\
      \ :]\n        sigma2 = float(np.mean(np.abs(n_eq) ** 2))\n        pn_finalized\
      \ = int(self._curr_pn)\n        with self._lock:\n            self.pn_list.append(pn_finalized)\n\
      \            self.mean_pilots_list.append(mean_p)\n            self.sigma2_list.append(sigma2)\n\
      \            if len(self.pn_list) % self.flush_every == 0:\n               \
      \ self._flush()\n        meta = pmt.make_dict()\n        meta = pmt.dict_add(meta,\
      \ pmt.intern('packet_num'), pmt.from_long(pn_finalized))\n        meta = pmt.dict_add(meta,\
      \ pmt.intern('kind'), pmt.intern('pilots'))\n        meta = pmt.dict_add(meta,\
      \ pmt.intern('sigma2'), pmt.from_double(sigma2))\n        self.message_port_pub(self.snr_part_port,\
      \ pmt.cons(meta, pmt.PMT_NIL))\n        self._curr_pn = None\n        self._curr_pilots\
      \ = []\n        self._curr_consumed = 0\n        self._curr_fl = 0\n\n    def\
      \ _flush(self):\n        if not self.pn_list:\n            return\n        np.savez(self.out_path,\n\
      \                 packet_num=np.array(self.pn_list, dtype=np.int64),\n     \
      \            mean_pilots=np.array(self.mean_pilots_list, dtype=np.complex64),\n\
      \                 sigma2=np.array(self.sigma2_list, dtype=np.float32))\n\n \
      \   def stop(self):\n        with self._lock:\n            self._flush()\n \
      \       print('[pilot_snr_logger] saved %d frames -> %s'\n              % (len(self.pn_list),\
      \ self.out_path))\n        return True\n"
    affinity: ''
    alias: ''
    comment: Per-frame equalized pilot logger for SNR estimation
    fft_len: fft_len
    flush_every: '200'
    maxoutbuf: '0'
    minoutbuf: '0'
    out_path: '"/tmp/pilot_dataset.npz"'
    pilot_positions: '[11, 25, 39, 53]'
    pilot_symbols: '[1.0, 1.0, 1.0, -1.0]'
  states:
    _io_cache: ('pilot_snr_logger', 'blk', [('fft_len', '64'), ('pilot_positions',
      '[11, 25, 39, 53]'), ('pilot_symbols', '[1.0, 1.0, 1.0, -1.0]'), ('out_path',
      "'/tmp/pilot_dataset.npz'"), ('flush_every', '200')], [('0', 'complex', 64)],
      [('snr_part', 'message', 1)], '', ['fft_len', 'flush_every', 'out_path', 'pilot_positions',
      'pilot_symbols'])
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1136, 1104.0]
    rotation: 0
    state: enabled
